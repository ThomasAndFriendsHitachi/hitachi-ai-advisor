# --- Node.js ---
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Docker ---
# Ignore the data directory if you map a volume for Postgres
postgres_data/
db_data/
redis_data/
# Ignore local overrides that shouldn't be shared
docker-compose.override.yml

# --- Environment Variables ---
# .env files contain secrets like DB passwords and API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Do NOT ignore .env.example (it acts as a template for others)
!.env.example

# --- Python (Agent) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/

# --- Build Outputs ---
dist/
build/
out/
.next/
bin/
obj/

# --- IDE & System Files ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
logs
*.log
npm-debug.log*